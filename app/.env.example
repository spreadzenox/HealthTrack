# Base URL of the API (leave empty if same origin or using Vite proxy in dev)
# VITE_API_URL=

# App version / build ID. Set this at build time to match backend APP_VERSION
# so users get the "new version" notification after a deploy.
# Example: git commit SHA, or semver (1.0.1)
# VITE_APP_VERSION=1.0.0
